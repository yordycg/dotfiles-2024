#!/usr/bin/env bash
# =============================================================================
# bin/git-gen-ssh
# Configura llave SSH para GitHub en Arch Linux (WSL2) usando GitHub CLI (gh).
# Idempotente. Exporta el agente SSH a ~/.ssh/agent.env para que el script
# padre pueda sourcear las variables y que git clone funcione en la misma sesión.
# =============================================================================

set -euo pipefail

# ──────────────────────────────────────────────────────────────────────────────
# CONFIGURACIÓN
# ──────────────────────────────────────────────────────────────────────────────
SSH_KEY_NAME="id_ed25519_github"
SSH_DIR="$HOME/.ssh"
SSH_KEY_PATH="$SSH_DIR/$SSH_KEY_NAME"
SSH_KEY_PUB_PATH="${SSH_KEY_PATH}.pub"
SSH_CONFIG_FILE="$SSH_DIR/config"

# Archivo donde se exportan las variables del agente para el proceso padre.
SSH_AGENT_ENV="${SSH_DIR}/agent.env"

# FIX 5: hostname compatible con WSL/Arch (sin depender de que exista el cmd).
_get_hostname() {
    if command -v hostname &>/dev/null; then
        hostname
    elif [[ -r /etc/hostname ]]; then
        tr -d '[:space:]' < /etc/hostname
    else
        echo "arch-wsl2"
    fi
}

KEY_COMMENT="GitHub automation key for $(_get_hostname)"
KEY_TITLE="GitHub Automation Key on $(_get_hostname)"

DOTFILES_DIR="${DOTFILES_DIR:-$HOME/workspace/infra/dotfiles-2024}"
DOTFILES_REMOTE="git@github.com:yordycg/dotfiles-2024.git"

# ──────────────────────────────────────────────────────────────────────────────
# HELPERS
# ──────────────────────────────────────────────────────────────────────────────
info()    { echo "  [INFO]  $*"; }
success() { echo "  [ OK ]  $*"; }
warn()    { echo "  [WARN]  $*"; }
die()     { echo "  [ERROR] $*" >&2; exit 1; }

# ──────────────────────────────────────────────────────────────────────────────
# PASO 0: Verificar dependencias
# ──────────────────────────────────────────────────────────────────────────────
echo ""
echo "=== Verificando dependencias ==="

for cmd in gh ssh-keygen jq; do
    command -v "$cmd" &>/dev/null \
        || die "'$cmd' no está instalado. Instálalo con: sudo pacman -S $cmd"
done
success "gh, ssh-keygen, jq encontrados."

# ──────────────────────────────────────────────────────────────────────────────
# PASO 1: Autenticación con GitHub CLI
# FIX 2: Solicitar explícitamente el scope admin:public_key.
# ──────────────────────────────────────────────────────────────────────────────
echo ""
echo "=== Verificando autenticación con GitHub CLI ==="

if ! gh auth status &>/dev/null; then
    warn "No autenticado. Iniciando login con scope 'admin:public_key'..."
    gh auth login --hostname github.com --scopes "admin:public_key,admin:ssh_signing_key" --web \
        || die "Falló la autenticación con GitHub CLI."
fi

# Verificar scope incluso si ya había sesión activa.
if ! gh auth status 2>&1 | grep -q "admin:public_key"; then
    warn "El token no tiene el scope 'admin:public_key'. Re-autenticando..."
    gh auth login --hostname github.com --scopes "admin:public_key,admin:ssh_signing_key" --web \
        || die "Falló la re-autenticación."
fi

success "GitHub CLI autenticado con los scopes correctos."

# ──────────────────────────────────────────────────────────────────────────────
# PASO 2: Crear directorio .ssh
# ──────────────────────────────────────────────────────────────────────────────
echo ""
echo "=== Preparando directorio ~/.ssh ==="

mkdir -p "$SSH_DIR"
chmod 700 "$SSH_DIR"
success "Directorio $SSH_DIR listo."

# ──────────────────────────────────────────────────────────────────────────────
# PASO 3: Generar llave SSH (idempotente)
# FIX 3: Si el par completo ya existe, se reutiliza sin preguntar.
# ──────────────────────────────────────────────────────────────────────────────
echo ""
echo "=== Generando llave SSH ==="

if [[ -f "$SSH_KEY_PATH" && -f "$SSH_KEY_PUB_PATH" ]]; then
    success "La llave '$SSH_KEY_NAME' ya existe localmente. Se reutilizará."
else
    # Estado corrupto: solo existe una parte del par → limpiar y regenerar.
    if [[ -f "$SSH_KEY_PATH" ]] || [[ -f "$SSH_KEY_PUB_PATH" ]]; then
        warn "Par de llaves incompleto. Limpiando y regenerando..."
        rm -f "$SSH_KEY_PATH" "$SSH_KEY_PUB_PATH"
    fi

    info "Generando nueva llave ed25519..."
    ssh-keygen -t ed25519 -f "$SSH_KEY_PATH" -N "" -C "$KEY_COMMENT" -q
    chmod 600 "$SSH_KEY_PATH"
    chmod 644 "$SSH_KEY_PUB_PATH"
    success "Llave generada: $SSH_KEY_PATH"
fi

# ──────────────────────────────────────────────────────────────────────────────
# PASO 4: Agente SSH
#
# PROBLEMA: eval "$(ssh-agent -s)" dentro de un subshell crea un agente cuyas
# variables (SSH_AUTH_SOCK, SSH_AGENT_PID) NO se propagan al proceso padre.
# Cuando el script hijo termina, el padre no sabe dónde está el agente
# → git clone falla con "Permission denied (publickey)".
#
# SOLUCIÓN: Guardar las variables en $SSH_AGENT_ENV para que el padre las
# sourcee inmediatamente después con: source "$HOME/.ssh/agent.env"
# ──────────────────────────────────────────────────────────────────────────────
echo ""
echo "=== Configurando agente SSH ==="

# Intentar reusar agente de ejecuciones anteriores.
if [[ -f "$SSH_AGENT_ENV" ]]; then
    # shellcheck source=/dev/null
    source "$SSH_AGENT_ENV" &>/dev/null || true
fi

# Verificación explícita en dos pasos:
# 1. ¿Existe el socket como archivo de tipo socket (-S)?
# 2. ¿Responde el agente? ssh-add -l: rc=0 (llaves), rc=1 (vivo/vacío), rc=2 (muerto).
_agent_rc=2
if [[ -n "${SSH_AUTH_SOCK:-}" && -S "${SSH_AUTH_SOCK:-/dev/null}" ]]; then
    ssh-add -l &>/dev/null && _agent_rc=0 || _agent_rc=$?
    # rc=0 o rc=1 → agente vivo; rc=2 → agente muerto
    [[ $_agent_rc -eq 1 ]] && _agent_rc=0
fi

if [[ $_agent_rc -ne 0 ]]; then
    info "Iniciando nuevo ssh-agent..."
    ssh-agent -s > "$SSH_AGENT_ENV"
    chmod 600 "$SSH_AGENT_ENV"
    # shellcheck source=/dev/null
    source "$SSH_AGENT_ENV" > /dev/null
    success "Agente SSH iniciado. Variables guardadas en $SSH_AGENT_ENV"
else
    success "Agente SSH ya está activo (socket: ${SSH_AUTH_SOCK})."
fi

# Agregar la llave solo si no está ya cargada.
if ! ssh-add -l 2>/dev/null | grep -qF "$SSH_KEY_PATH"; then
    ssh-add "$SSH_KEY_PATH" \
        && success "Llave agregada al agente." \
        || die "No se pudo agregar la llave al agente."
else
    success "La llave ya estaba cargada en el agente."
fi

# ──────────────────────────────────────────────────────────────────────────────
# PASO 5: Subir llave a GitHub
# FIX 1: --json id,title + jq en vez de grep/awk que cortaba mal los IDs
#         y causaba errores 404.
# FIX 3: Idempotente — detecta por título exacto si ya existe.
# ──────────────────────────────────────────────────────────────────────────────
echo ""
echo "=== Sincronizando llave con GitHub ==="

# gh ssh-key list --json no está disponible en todas las versiones de gh.
# Usamos el formato de texto plano y buscamos el título con grep.
# El formato de salida es: <ID>  <TITLE>  <TYPE>  <CREATED_AT>
EXISTING_KEY_ID=$(gh ssh-key list 2>/dev/null \
    | grep -F "$KEY_TITLE" \
    | awk '{print $1}' \
    || true)

if [[ -n "$EXISTING_KEY_ID" ]]; then
    success "La llave ya existe en GitHub (ID: $EXISTING_KEY_ID). No se sube de nuevo."
else
    info "Subiendo llave pública a GitHub con título '$KEY_TITLE'..."
    gh ssh-key add "$SSH_KEY_PUB_PATH" --title "$KEY_TITLE" \
        || die "Falló al subir la llave. Verifica el scope 'admin:public_key'."
    success "Llave subida correctamente a GitHub."
fi

# ──────────────────────────────────────────────────────────────────────────────
# PASO 6: Configurar ~/.ssh/config
# FIX 4: Marcador único para detectar el bloque ya escrito y evitar duplicados.
# ──────────────────────────────────────────────────────────────────────────────
echo ""
echo "=== Configurando ~/.ssh/config ==="

SSH_CONFIG_MARKER="# BEGIN github.com block (setup_github_ssh)"

if [[ -f "$SSH_CONFIG_FILE" ]] && grep -qF "$SSH_CONFIG_MARKER" "$SSH_CONFIG_FILE"; then
    success "Bloque github.com ya existe en $SSH_CONFIG_FILE."
else
    info "Agregando bloque github.com en $SSH_CONFIG_FILE..."
    cat >> "$SSH_CONFIG_FILE" <<EOF

${SSH_CONFIG_MARKER}
Host github.com
    HostName github.com
    User git
    IdentityFile ${SSH_KEY_PATH}
    IdentitiesOnly yes
# END github.com block (setup_github_ssh)
EOF
    chmod 600 "$SSH_CONFIG_FILE"
    success "Configuración SSH escrita en $SSH_CONFIG_FILE."
fi

# ──────────────────────────────────────────────────────────────────────────────
# PASO 7: Actualizar remote dotfiles (opcional)
# ──────────────────────────────────────────────────────────────────────────────
echo ""
echo "=== Verificando repositorio dotfiles ==="

if [[ -d "$DOTFILES_DIR/.git" ]]; then
    (cd "$DOTFILES_DIR" && git remote set-url origin "$DOTFILES_REMOTE")
    success "Remote 'origin' actualizado a: $DOTFILES_REMOTE"
else
    info "Directorio $DOTFILES_DIR no es un repo git. Saltando."
fi

# ──────────────────────────────────────────────────────────────────────────────
# VERIFICACIÓN FINAL
#
# CRÍTICO: Retornamos exit 1 si SSH no funciona para que el script padre
# pueda abortar el flujo en vez de continuar y fallar silenciosamente
# en el git clone con "Permission denied (publickey)".
# ──────────────────────────────────────────────────────────────────────────────
echo ""
echo "=== Verificación de conexión con GitHub ==="

SSH_TEST=$(ssh -T git@github.com \
    -o StrictHostKeyChecking=accept-new \
    -o ConnectTimeout=10 \
    2>&1 || true)

if echo "$SSH_TEST" | grep -q "successfully authenticated"; then
    success "Conexión SSH con GitHub: OK"
else
    echo "  [ERROR] Falló la verificación SSH. Salida:" >&2
    echo "          $SSH_TEST" >&2
    echo "" >&2
    echo "  Posibles causas:" >&2
    echo "    1. La llave no fue aceptada por GitHub aún." >&2
    echo "    2. El agente no tiene la llave cargada." >&2
    echo "    3. ~/.ssh/config apunta a la llave incorrecta." >&2
    echo "" >&2
    echo "  Diagnóstico manual:" >&2
    echo "    source ~/.ssh/agent.env && ssh -vT git@github.com" >&2
    exit 1
fi

echo ""
echo "=== Setup SSH completado exitosamente ==="
