# -- Git Configuration (Windows - Synced with Chezmoi) --

[user]
    name = Yordy Carmona
    email = yordy.carmona8@gmail.com

[core]
    autocrlf = true
    editor = nvim
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    light = false
    side-by-side = true
    line-numbers = true

[merge]
    conflictstyle = zdiff3

[diff]
    colorMoved = default

[pull]
    rebase = true

[push]
    autoSetupRemote = true

[init]
    defaultBranch = main

# Condicionales para perfiles específicos (Si existen en Windows)
[includeIf "gitdir:~/workspace/work/"]
    path = .gitconfig-work

[includeIf "gitdir:~/workspace/ipvg/"]
    path = .gitconfig-ipvg

[includeIf "gitdir:~/workspace/personal/"]
    path = .gitconfig-personal
